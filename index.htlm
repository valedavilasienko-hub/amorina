<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#8c5f43" />
  <title>Amorina | Home Scents Córdoba</title>
  <meta name="description" content="Amorina Córdoba. Aromas, velas, difusores y productos para el hogar." />
  <style>
    :root{
      --bg:#f7f0e8;
      --paper:#fffaf5;
      --ink:#2e211b;
      --muted:#796a61;
      --brown:#8c5f43;
      --brown2:#5d3c2c;
      --terracotta:#b97555;
      --line:#e8d9cc;
      --soft:#ead8c8;
      --success:#2e6c4f;
      --danger:#a83f36;
      --shadow:0 20px 60px rgba(77,47,31,.12);
      --radius:22px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;background:var(--bg);color:var(--ink);
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    }
    button,input,select,textarea{font:inherit}
    button{cursor:pointer}
    a{text-decoration:none;color:inherit}
    .serif{font-family:Georgia,"Times New Roman",serif}
    .container{width:min(1180px,92vw);margin:auto}
    .hidden{display:none!important}

    /* HEADER */
    header{
      position:sticky;top:0;z-index:40;
      background:rgba(247,240,232,.90);backdrop-filter:blur(16px);
      border-bottom:1px solid rgba(93,60,44,.08);
    }
    .nav{
      height:78px;display:flex;align-items:center;justify-content:space-between;gap:18px;
    }
    .brand{font-family:Georgia,serif;font-size:30px;letter-spacing:.08em}
    .navlinks{display:flex;gap:28px;align-items:center;font-size:14px}
    .navlinks a:hover{color:var(--brown)}
    .nav-actions{display:flex;align-items:center;gap:10px}
    .icon-btn{
      width:44px;height:44px;border:1px solid var(--line);background:var(--paper);
      border-radius:50%;display:grid;place-items:center;color:var(--ink)
    }
    .cart-btn{position:relative}
    .cart-count{
      position:absolute;right:-4px;top:-5px;background:var(--brown2);color:white;
      min-width:20px;height:20px;padding:0 5px;border-radius:20px;font-size:11px;
      display:grid;place-items:center;
    }
    .menu-btn{display:none}

    /* HERO */
    .hero{padding:34px 0 54px}
    .hero-grid{
      min-height:610px;display:grid;grid-template-columns:1.1fr .9fr;
      border-radius:32px;overflow:hidden;background:#d7b99d;box-shadow:var(--shadow);
    }
    .hero-copy{
      padding:clamp(42px,7vw,90px);display:flex;flex-direction:column;justify-content:center;
      background:
        radial-gradient(circle at 85% 20%,rgba(255,255,255,.35),transparent 30%),
        linear-gradient(135deg,#e8d2bc,#c99873);
    }
    .eyebrow{text-transform:uppercase;letter-spacing:.24em;font-size:12px;margin-bottom:22px}
    .hero h1{
      font-family:Georgia,serif;font-weight:400;font-size:clamp(52px,7vw,94px);
      line-height:.95;margin:0 0 24px;
    }
    .hero p{font-size:18px;line-height:1.65;max-width:520px;margin:0 0 32px}
    .cta-row{display:flex;gap:12px;flex-wrap:wrap}
    .btn{
      border:none;border-radius:999px;padding:14px 22px;transition:.2s ease;
      display:inline-flex;align-items:center;justify-content:center;gap:10px;font-weight:650;
    }
    .btn-primary{background:var(--brown2);color:#fff}
    .btn-primary:hover{transform:translateY(-2px);background:#442a20}
    .btn-soft{background:rgba(255,255,255,.55);color:var(--ink);border:1px solid rgba(255,255,255,.55)}
    .hero-art{
      min-height:610px;position:relative;overflow:hidden;
      background:linear-gradient(160deg,#764b33,#b16f4d 45%,#e8c7ab);
    }
    .hero-art:before{
      content:"";position:absolute;inset:8% 12% 0;border-radius:180px 180px 0 0;
      background:rgba(255,244,232,.18);border:1px solid rgba(255,255,255,.25);
    }
    .bottle{
      position:absolute;left:50%;top:52%;transform:translate(-50%,-50%);
      width:180px;height:320px;border-radius:32px 32px 44px 44px;
      background:linear-gradient(90deg,#3f2419,#6d3c25,#2d190f);
      box-shadow:0 35px 50px rgba(35,16,8,.34);
    }
    .bottle:before{
      content:"";position:absolute;width:80px;height:70px;left:50%;top:-55px;transform:translateX(-50%);
      background:#17130f;border-radius:12px 12px 5px 5px;
    }
    .bottle:after{
      content:"AMORINA\A home scents";white-space:pre;
      position:absolute;left:24px;right:24px;top:115px;height:100px;border-radius:10px;
      background:#f4eee8;color:#4f3425;display:grid;place-items:center;text-align:center;
      font-family:Georgia,serif;line-height:1.8;font-size:15px;
    }
    .reeds{position:absolute;left:50%;top:3%;width:7px;height:220px;background:#d7b17e;transform-origin:bottom}
    .reeds.r1{transform:rotate(-10deg)} .reeds.r2{transform:rotate(3deg)} .reeds.r3{transform:rotate(15deg)}
    .hero-note{
      position:absolute;right:26px;bottom:25px;color:#fff;font-family:Georgia,serif;
      font-style:italic;font-size:22px;opacity:.85
    }

    /* SECTIONS */
    section{padding:72px 0}
    .section-head{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:28px}
    .section-head h2{font-family:Georgia,serif;font-weight:400;font-size:clamp(34px,4vw,52px);margin:0}
    .section-head p{margin:8px 0 0;color:var(--muted)}
    .link-arrow{font-size:14px;font-weight:650}

    .filters{
      display:flex;gap:10px;flex-wrap:wrap;margin:0 0 26px
    }
    .filter-btn{
      border:1px solid var(--line);background:rgba(255,255,255,.42);border-radius:999px;
      padding:10px 16px;color:var(--ink)
    }
    .filter-btn.active{background:var(--brown2);color:#fff;border-color:var(--brown2)}
    .catalog-toolbar{
      display:grid;grid-template-columns:1fr 190px;gap:12px;margin-bottom:24px
    }
    .search,.select,.field{
      width:100%;border:1px solid var(--line);background:var(--paper);border-radius:14px;
      padding:13px 14px;outline:none;color:var(--ink)
    }
    .search:focus,.select:focus,.field:focus{border-color:var(--brown)}

    .products{
      display:grid;grid-template-columns:repeat(4,1fr);gap:18px
    }
    .product{
      background:var(--paper);border-radius:20px;overflow:hidden;border:1px solid rgba(93,60,44,.08);
      transition:.2s ease
    }
    .product:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
    .product-image{
      aspect-ratio:4/5;background:linear-gradient(145deg,#e5cab0,#a86745);
      position:relative;display:grid;place-items:center;overflow:hidden
    }
    .product-image img{width:100%;height:100%;object-fit:cover;display:block}
    .product-placeholder{
      width:80px;height:160px;border-radius:16px;background:linear-gradient(90deg,#362117,#70462e,#321c13);
      box-shadow:0 25px 35px rgba(40,20,10,.25);position:relative
    }
    .product-placeholder:after{
      content:"AMORINA";position:absolute;left:10px;right:10px;top:58px;padding:14px 3px;
      text-align:center;background:#f4eee7;font-family:Georgia,serif;font-size:10px;border-radius:4px
    }
    .badge{
      position:absolute;left:12px;top:12px;background:rgba(255,250,245,.88);
      padding:7px 10px;border-radius:999px;font-size:11px
    }
    .product-body{padding:16px}
    .product-cat{font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted)}
    .product h3{font-family:Georgia,serif;font-weight:400;font-size:22px;margin:8px 0}
    .price{font-weight:700;margin-bottom:14px}
    .product-actions{display:grid;grid-template-columns:1fr 46px;gap:8px}
    .add-btn{border:none;background:var(--brown2);color:white;border-radius:12px;padding:12px 10px;font-weight:650}
    .wa-mini{border:1px solid var(--line);background:#fff;border-radius:12px}

    .story{
      display:grid;grid-template-columns:1fr 1fr;border-radius:28px;overflow:hidden;background:#ccb094
    }
    .story-copy{padding:clamp(40px,7vw,90px);display:flex;flex-direction:column;justify-content:center}
    .story-copy h2{font-family:Georgia,serif;font-size:clamp(38px,5vw,62px);font-weight:400;margin:0 0 22px}
    .story-copy p{line-height:1.8;color:#49382f}
    .story-art{
      min-height:500px;background:
        radial-gradient(circle at 35% 34%,rgba(255,246,235,.8) 0 8%,transparent 8.5%),
        radial-gradient(circle at 62% 62%,rgba(112,64,39,.48) 0 18%,transparent 18.5%),
        linear-gradient(145deg,#e3c8ac,#9a6245);
      position:relative
    }

    .contact-card{
      display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;
      padding:36px;border-radius:24px;background:var(--brown2);color:#fff
    }
    .contact-card h2{font-family:Georgia,serif;font-weight:400;font-size:38px;margin:0 0 8px}
    .contact-card p{margin:0;color:#eaded7}

    footer{padding:38px 0 50px;border-top:1px solid var(--line)}
    .footer-row{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
    .admin-link{opacity:.45;font-size:12px;border:none;background:none;color:inherit}

    /* DRAWER / CART */
    .overlay{position:fixed;inset:0;background:rgba(30,20,15,.46);z-index:80;display:none}
    .overlay.show{display:block}
    .drawer{
      position:fixed;right:0;top:0;bottom:0;width:min(470px,100%);z-index:90;background:var(--paper);
      transform:translateX(100%);transition:.28s ease;display:flex;flex-direction:column
    }
    .drawer.show{transform:translateX(0)}
    .drawer-head{padding:22px 22px 16px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
    .drawer-body{padding:18px 22px;overflow:auto;flex:1}
    .cart-item{
      display:grid;grid-template-columns:72px 1fr auto;gap:12px;padding:12px 0;border-bottom:1px solid var(--line)
    }
    .cart-thumb{width:72px;height:86px;border-radius:10px;object-fit:cover;background:#d8b99d}
    .qty{display:flex;align-items:center;gap:8px;margin-top:8px}
    .qty button{width:28px;height:28px;border-radius:50%;border:1px solid var(--line);background:white}
    .drawer-foot{padding:18px 22px 24px;border-top:1px solid var(--line);background:#fffaf5}
    .total-row{display:flex;justify-content:space-between;font-size:20px;font-weight:700;margin-bottom:14px}

    /* MODAL CHECKOUT */
    .modal{
      position:fixed;inset:0;z-index:120;display:none;place-items:center;padding:18px;background:rgba(30,20,15,.52)
    }
    .modal.show{display:grid}
    .modal-card{
      width:min(680px,100%);max-height:92vh;overflow:auto;background:var(--paper);
      border-radius:24px;padding:24px;box-shadow:var(--shadow)
    }
    .modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
    .modal-head h3{font-family:Georgia,serif;font-size:32px;font-weight:400;margin:0}
    .close-btn{border:none;background:transparent;font-size:28px}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .full{grid-column:1/-1}
    label{font-size:12px;font-weight:700;display:block;margin:4px 0 6px}
    .radio-row{display:flex;gap:10px;flex-wrap:wrap}
    .radio-card{
      flex:1;min-width:170px;border:1px solid var(--line);border-radius:14px;padding:13px;background:white
    }
    .checkout-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px}
    .btn-mp{background:#009ee3;color:white}
    .btn-wa{background:#25D366;color:#0b3a1c}
    .notice{font-size:12px;color:var(--muted);line-height:1.5;margin-top:12px}

    /* ADMIN */
    .admin{
      position:fixed;inset:0;z-index:200;background:#f4ede6;display:none;overflow:auto
    }
    .admin.show{display:block}
    .admin-login{
      min-height:100vh;display:grid;place-items:center;padding:22px
    }
    .login-card{
      width:min(430px,100%);background:var(--paper);padding:30px;border-radius:24px;box-shadow:var(--shadow)
    }
    .login-card h1{font-family:Georgia,serif;font-weight:400;font-size:42px;margin:0 0 6px}
    .login-card p{color:var(--muted);margin:0 0 22px}
    .stack{display:grid;gap:12px}
    .admin-shell{min-height:100vh;display:grid;grid-template-columns:250px 1fr}
    .sidebar{background:#342219;color:white;padding:28px 18px;position:sticky;top:0;height:100vh}
    .sidebar .brand{padding:0 10px 28px;display:block}
    .side-btn{
      width:100%;text-align:left;border:none;background:transparent;color:#eaded6;
      border-radius:12px;padding:12px 14px;margin:3px 0
    }
    .side-btn.active,.side-btn:hover{background:rgba(255,255,255,.10);color:white}
    .admin-main{padding:34px}
    .admin-top{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:28px}
    .admin-top h2{font-family:Georgia,serif;font-weight:400;font-size:42px;margin:0}
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
    .stat{background:var(--paper);padding:22px;border-radius:18px;border:1px solid var(--line)}
    .stat small{color:var(--muted)}
    .stat strong{display:block;font-family:Georgia,serif;font-size:30px;margin-top:8px}
    .admin-card{margin-top:18px;background:var(--paper);border:1px solid var(--line);border-radius:18px;padding:20px;overflow:auto}
    table{width:100%;border-collapse:collapse;min-width:700px}
    th,td{padding:13px 10px;border-bottom:1px solid var(--line);text-align:left;font-size:13px}
    th{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.08em}
    .small-btn{border:none;border-radius:9px;padding:8px 10px}
    .edit{background:#efe1d4}.delete{background:#f5d9d6;color:#7f2d27}
    .admin-form{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .admin-form .full{grid-column:1/-1}

    @media(max-width:950px){
      .products{grid-template-columns:repeat(2,1fr)}
      .hero-grid,.story{grid-template-columns:1fr}
      .hero-art{min-height:500px}
      .stats{grid-template-columns:repeat(2,1fr)}
      .admin-shell{grid-template-columns:1fr}
      .sidebar{position:relative;height:auto}
    }
    @media(max-width:700px){
      .navlinks{display:none}
      .menu-btn{display:grid}
      .hero{padding-top:18px}
      .hero-grid{min-height:unset;border-radius:24px}
      .hero-copy{padding:42px 25px}
      .hero-art{min-height:420px}
      .products{grid-template-columns:1fr 1fr;gap:10px}
      .product h3{font-size:18px}
      .product-body{padding:12px}
      .catalog-toolbar{grid-template-columns:1fr}
      section{padding:52px 0}
      .section-head{align-items:start;flex-direction:column}
      .contact-card{grid-template-columns:1fr}
      .form-grid,.checkout-actions,.admin-form{grid-template-columns:1fr}
      .full,.admin-form .full{grid-column:auto}
      .admin-main{padding:22px 15px}
      .stats{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>

<header>
  <div class="container nav">
    <a href="#inicio" class="brand">AMORINA</a>
    <nav class="navlinks">
      <a href="#inicio">Inicio</a>
      <a href="#catalogo">Catálogo</a>
      <a href="#contacto">Contacto</a>
    </nav>
    <div class="nav-actions">
      <button class="icon-btn" onclick="document.getElementById('catalogSearch').focus();location.hash='catalogo'" aria-label="Buscar">⌕</button>
      <button class="icon-btn cart-btn" onclick="openCart()" aria-label="Carrito">
        🛒 <span class="cart-count" id="cartCount">0</span>
      </button>
    </div>
  </div>
</header>

<main>
  <section class="hero" id="inicio">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">Home scents · Córdoba</div>
        <h1>Aromas que hacen hogar.</h1>
        <p>Velas, difusores y fragancias pensadas para transformar lo cotidiano en una experiencia más cálida.</p>
        <div class="cta-row">
          <a class="btn btn-primary" href="#catalogo">Ver catálogo</a>
          <a class="btn btn-soft" href="#contacto">Consultar</a>
        </div>
      </div>
      <div class="hero-art">
        <div class="reeds r1"></div><div class="reeds r2"></div><div class="reeds r3"></div>
        <div class="bottle"></div>
        <div class="hero-note">Amorina Córdoba</div>
      </div>
    </div>
  </section>

  <section id="catalogo">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Catálogo</h2>
          <p>Explorá todos los productos y filtrá por categoría.</p>
        </div>
        <span class="link-arrow" id="productCounter"></span>
      </div>

      <div class="filters" id="categoryFilters"></div>

      <div class="catalog-toolbar">
        <input id="catalogSearch" class="search" placeholder="Buscar productos..." oninput="renderProducts()" />
        <select id="catalogSort" class="select" onchange="renderProducts()">
          <option value="featured">Destacados</option>
          <option value="low">Menor precio</option>
          <option value="high">Mayor precio</option>
          <option value="az">Nombre A-Z</option>
        </select>
      </div>

      <div class="products" id="productGrid"></div>
    </div>
  </section>

  <section>
    <div class="container story">
      <div class="story-copy">
        <div class="eyebrow">AMORINA</div>
        <h2>Un aroma puede cambiar por completo un espacio.</h2>
        <p>Elegimos una estética cálida, simple y sensorial. El catálogo reúne todas las líneas de Amorina en un solo lugar para que encontrar tu aroma sea fácil.</p>
        <div><a class="btn btn-primary" href="#catalogo">Explorar productos</a></div>
      </div>
      <div class="story-art"></div>
    </div>
  </section>

  <section id="contacto">
    <div class="container">
      <div class="contact-card">
        <div>
          <h2>¿Necesitás ayuda con tu compra?</h2>
          <p>Escribinos por WhatsApp y te ayudamos a elegir productos, aromas, envío o retiro.</p>
        </div>
        <button class="btn btn-soft" onclick="openGeneralWhatsApp()">Hablar por WhatsApp</button>
      </div>
    </div>
  </section>
</main>

<footer>
  <div class="container footer-row">
    <div>
      <div class="brand">AMORINA</div>
      <small id="footerInstagram">Home Scents · Córdoba</small>
    </div>
    <div>
      <small>© <span id="year"></span> Amorina Córdoba</small>
      <button class="admin-link" onclick="openAdmin()">Administración</button>
    </div>
  </div>
</footer>

<div class="overlay" id="overlay" onclick="closeCart()"></div>
<aside class="drawer" id="cartDrawer">
  <div class="drawer-head">
    <strong>Tu pedido</strong>
    <button class="close-btn" onclick="closeCart()">×</button>
  </div>
  <div class="drawer-body" id="cartItems"></div>
  <div class="drawer-foot">
    <div class="total-row"><span>Total</span><span id="cartTotal">$0</span></div>
    <button class="btn btn-primary" style="width:100%" onclick="startCheckout()">Continuar</button>
  </div>
</aside>

<div class="modal" id="checkoutModal">
  <div class="modal-card">
    <div class="modal-head">
      <h3>Finalizar pedido</h3>
      <button class="close-btn" onclick="closeCheckout()">×</button>
    </div>

    <div class="form-grid">
      <div>
        <label>Nombre y apellido</label>
        <input class="field" id="cName" placeholder="Tu nombre" />
      </div>
      <div>
        <label>Teléfono</label>
        <input class="field" id="cPhone" placeholder="351..." />
      </div>

      <div class="full">
        <label>Forma de entrega</label>
        <div class="radio-row">
          <label class="radio-card"><input type="radio" name="delivery" value="delivery" checked onchange="toggleAddress()"> Envío a domicilio</label>
          <label class="radio-card"><input type="radio" name="delivery" value="pickup" onchange="toggleAddress()"> Retiro</label>
        </div>
      </div>

      <div id="addressWrap">
        <label>Dirección</label>
        <input class="field" id="cAddress" placeholder="Calle, número, piso/depto" />
      </div>
      <div id="areaWrap">
        <label>Barrio / localidad</label>
        <input class="field" id="cArea" placeholder="Nueva Córdoba, General Paz..." />
      </div>

      <div class="full">
        <label>Aclaraciones</label>
        <textarea class="field" id="cNotes" rows="3" placeholder="Timbre, referencia, horario, etc."></textarea>
      </div>
    </div>

    <div class="checkout-actions">
      <button class="btn btn-mp" onclick="payMercadoPago()">Pagar con Mercado Pago</button>
      <button class="btn btn-wa" onclick="sendWhatsAppOrder()">Enviar por WhatsApp</button>
    </div>

    <div class="notice">
      Mercado Pago requiere un backend seguro para crear la preferencia de pago. Este archivo llama al endpoint configurado en Administración. No coloques un Access Token privado directamente en el HTML.
    </div>
  </div>
</div>

<!-- ADMIN -->
<div class="admin" id="adminPanel">
  <div class="admin-login" id="adminLogin">
    <div class="login-card">
      <h1>AMORINA</h1>
      <p>Portal privado de administración</p>
      <div class="stack">
        <input class="field" id="adminPass" type="password" placeholder="Contraseña" />
        <button class="btn btn-primary" onclick="loginAdmin()">Ingresar</button>
        <button class="btn btn-soft" onclick="closeAdmin()">Volver a la tienda</button>
      </div>
      <p class="notice">Modo demostración: para un portal realmente privado usá Firebase Authentication o un backend. Una contraseña guardada solo en el navegador no es seguridad real.</p>
    </div>
  </div>

  <div class="admin-shell hidden" id="adminShell">
    <aside class="sidebar">
      <span class="brand">AMORINA</span>
      <button class="side-btn active" onclick="adminView('dashboard',this)">Dashboard</button>
      <button class="side-btn" onclick="adminView('products',this)">Productos</button>
      <button class="side-btn" onclick="adminView('categories',this)">Categorías</button>
      <button class="side-btn" onclick="adminView('orders',this)">Pedidos</button>
      <button class="side-btn" onclick="adminView('settings',this)">Configuración</button>
      <button class="side-btn" onclick="closeAdmin()">← Volver a la tienda</button>
    </aside>
    <main class="admin-main">
      <div class="admin-top">
        <h2 id="adminTitle">Dashboard</h2>
        <button class="btn btn-primary" id="adminPrimary" onclick="openProductForm()">+ Agregar producto</button>
      </div>
      <div id="adminContent"></div>
    </main>
  </div>
</div>

<script>
const DEFAULT_PRODUCTS = [
  {id:1,name:"Vervain Lime",category:"Velas",price:14500,stock:10,featured:true,image:""},
  {id:2,name:"Caffè Dolce",category:"Velas",price:15900,stock:8,featured:true,image:""},
  {id:3,name:"Difusor Vervain",category:"Difusores",price:18900,stock:12,featured:true,image:""},
  {id:4,name:"Home Spray",category:"Home Spray",price:13200,stock:15,featured:false,image:""},
  {id:5,name:"Hand Wash",category:"Cuidado personal",price:11800,stock:7,featured:false,image:""},
  {id:6,name:"Room & Linen Spray",category:"Textil",price:13900,stock:9,featured:true,image:""}
];

const DEFAULT_SETTINGS = {
  whatsapp:"",
  instagram:"",
  pickupAddress:"Córdoba Capital",
  shippingCost:0,
  freeShippingFrom:0,
  mpEndpoint:"/api/mercadopago/create-preference",
  adminPassword:"amorina2026"
};

let products = JSON.parse(localStorage.getItem("amorina_products") || "null") || DEFAULT_PRODUCTS;
let settings = {...DEFAULT_SETTINGS, ...(JSON.parse(localStorage.getItem("amorina_settings") || "{}"))};
let orders = JSON.parse(localStorage.getItem("amorina_orders") || "[]");
let cart = JSON.parse(localStorage.getItem("amorina_cart") || "[]");
let activeCategory = "Todos";
let editingProductId = null;

function money(v){return new Intl.NumberFormat("es-AR",{style:"currency",currency:"ARS",maximumFractionDigits:0}).format(v)}
function persist(){
  localStorage.setItem("amorina_products",JSON.stringify(products));
  localStorage.setItem("amorina_settings",JSON.stringify(settings));
  localStorage.setItem("amorina_orders",JSON.stringify(orders));
  localStorage.setItem("amorina_cart",JSON.stringify(cart));
}
function categories(){return ["Todos",...new Set(products.map(p=>p.category).filter(Boolean))]}

function renderFilters(){
  const box=document.getElementById("categoryFilters");
  box.innerHTML=categories().map(c=>`<button class="filter-btn ${activeCategory===c?'active':''}" onclick="setCategory('${escapeJs(c)}')">${escapeHtml(c)}</button>`).join("");
}
function setCategory(c){activeCategory=c;renderFilters();renderProducts()}

function renderProducts(){
  const q=(document.getElementById("catalogSearch").value||"").toLowerCase().trim();
  const sort=document.getElementById("catalogSort").value;
  let list=products.filter(p=>(activeCategory==="Todos"||p.category===activeCategory) && p.name.toLowerCase().includes(q));
  if(sort==="low") list.sort((a,b)=>a.price-b.price);
  if(sort==="high") list.sort((a,b)=>b.price-a.price);
  if(sort==="az") list.sort((a,b)=>a.name.localeCompare(b.name));
  if(sort==="featured") list.sort((a,b)=>Number(b.featured)-Number(a.featured));
  document.getElementById("productCounter").textContent=`${list.length} productos`;
  document.getElementById("productGrid").innerHTML=list.map(productCard).join("") || `<p>No encontramos productos con esos filtros.</p>`;
}
function productCard(p){
  const img=p.image ? `<img src="${escapeAttr(p.image)}" alt="${escapeAttr(p.name)}">` : `<div class="product-placeholder"></div>`;
  return `<article class="product">
    <div class="product-image">${img}${p.featured?'<span class="badge">Destacado</span>':''}</div>
    <div class="product-body">
      <div class="product-cat">${escapeHtml(p.category)}</div>
      <h3>${escapeHtml(p.name)}</h3>
      <div class="price">${money(p.price)}</div>
      <div class="product-actions">
        <button class="add-btn" onclick="addToCart(${p.id})" ${p.stock<=0?'disabled':''}>${p.stock<=0?'Sin stock':'Agregar'}</button>
        <button class="wa-mini" title="Consultar por WhatsApp" onclick="productWhatsApp(${p.id})">WA</button>
      </div>
    </div>
  </article>`;
}

function addToCart(id){
  const p=products.find(x=>x.id===id); if(!p||p.stock<=0)return;
  const item=cart.find(x=>x.id===id);
  if(item){ if(item.qty<p.stock)item.qty++; } else cart.push({id,qty:1});
  persist();renderCart();openCart();
}
function changeQty(id,delta){
  const item=cart.find(x=>x.id===id), p=products.find(x=>x.id===id);
  if(!item||!p)return;
  item.qty=Math.max(0,Math.min(p.stock,item.qty+delta));
  cart=cart.filter(x=>x.qty>0);persist();renderCart();
}
function cartTotal(){return cart.reduce((sum,i)=>{const p=products.find(x=>x.id===i.id);return sum+(p?p.price*i.qty:0)},0)}
function renderCart(){
  document.getElementById("cartCount").textContent=cart.reduce((s,i)=>s+i.qty,0);
  const box=document.getElementById("cartItems");
  if(!cart.length){box.innerHTML="<p>Tu carrito está vacío.</p>"}
  else box.innerHTML=cart.map(i=>{
    const p=products.find(x=>x.id===i.id); if(!p)return "";
    return `<div class="cart-item">
      <div class="cart-thumb">${p.image?`<img src="${escapeAttr(p.image)}" style="width:100%;height:100%;object-fit:cover;border-radius:10px">`:""}</div>
      <div><strong>${escapeHtml(p.name)}</strong><div>${money(p.price)}</div>
        <div class="qty"><button onclick="changeQty(${p.id},-1)">−</button><span>${i.qty}</span><button onclick="changeQty(${p.id},1)">+</button></div>
      </div>
      <strong>${money(p.price*i.qty)}</strong>
    </div>`
  }).join("");
  document.getElementById("cartTotal").textContent=money(cartTotal());
}
function openCart(){document.getElementById("cartDrawer").classList.add("show");document.getElementById("overlay").classList.add("show")}
function closeCart(){document.getElementById("cartDrawer").classList.remove("show");document.getElementById("overlay").classList.remove("show")}

function startCheckout(){
  if(!cart.length)return alert("Agregá al menos un producto.");
  closeCart();document.getElementById("checkoutModal").classList.add("show");toggleAddress();
}
function closeCheckout(){document.getElementById("checkoutModal").classList.remove("show")}
function deliveryType(){return document.querySelector('input[name="delivery"]:checked').value}
function toggleAddress(){
  const delivery=deliveryType()==="delivery";
  document.getElementById("addressWrap").style.display=delivery?"block":"none";
  document.getElementById("areaWrap").style.display=delivery?"block":"none";
}
function checkoutData(){
  const data={
    name:document.getElementById("cName").value.trim(),
    phone:document.getElementById("cPhone").value.trim(),
    delivery:deliveryType(),
    address:document.getElementById("cAddress").value.trim(),
    area:document.getElementById("cArea").value.trim(),
    notes:document.getElementById("cNotes").value.trim()
  };
  if(!data.name||!data.phone)throw new Error("Completá nombre y teléfono.");
  if(data.delivery==="delivery"&&!data.address)throw new Error("Completá la dirección de entrega.");
  return data;
}
function orderSnapshot(data,payment){
  return {
    id:Date.now(),
    createdAt:new Date().toISOString(),
    status:"Nuevo",
    payment,
    customer:data,
    items:cart.map(i=>{const p=products.find(x=>x.id===i.id);return {id:p.id,name:p.name,price:p.price,qty:i.qty}}),
    total:cartTotal()
  }
}
function saveOrder(order){orders.unshift(order);persist()}

function whatsappNumber(){
  return (settings.whatsapp||"").replace(/\D/g,"");
}
function openGeneralWhatsApp(){
  const n=whatsappNumber();
  if(!n)return alert("El número de WhatsApp todavía no está configurado en Administración.");
  window.open(`https://wa.me/${n}?text=${encodeURIComponent("Hola Amorina, quería hacer una consulta.")}`,"_blank");
}
function productWhatsApp(id){
  const p=products.find(x=>x.id===id), n=whatsappNumber();
  if(!n)return alert("El número de WhatsApp todavía no está configurado.");
  window.open(`https://wa.me/${n}?text=${encodeURIComponent(`Hola Amorina, quería consultar por ${p.name} (${money(p.price)}).`)}`,"_blank");
}
function buildWhatsAppMessage(data){
  let msg=`Hola, quiero realizar un pedido en Amorina 🌿\n\n*Pedido:*\n`;
  cart.forEach(i=>{const p=products.find(x=>x.id===i.id);msg+=`${i.qty} × ${p.name} — ${money(p.price*i.qty)}\n`});
  msg+=`\n*Total:* ${money(cartTotal())}\n\n*Cliente:* ${data.name}\n*Teléfono:* ${data.phone}\n`;
  if(data.delivery==="delivery"){
    msg+=`*Entrega:* Envío a domicilio\n*Dirección:* ${data.address}\n*Barrio/localidad:* ${data.area||"-"}\n`;
  } else msg+=`*Entrega:* Retiro\n*Punto de retiro:* ${settings.pickupAddress||"-"}\n`;
  if(data.notes)msg+=`*Aclaraciones:* ${data.notes}\n`;
  return msg;
}
function sendWhatsAppOrder(){
  try{
    const data=checkoutData(), n=whatsappNumber();
    if(!n)return alert("Configurá el WhatsApp desde Administración.");
    const order=orderSnapshot(data,"WhatsApp / pendiente");
    saveOrder(order);
    window.open(`https://wa.me/${n}?text=${encodeURIComponent(buildWhatsAppMessage(data))}`,"_blank");
  }catch(e){alert(e.message)}
}

async function payMercadoPago(){
  try{
    const data=checkoutData();
    const endpoint=settings.mpEndpoint?.trim();
    if(!endpoint)return alert("Configurá el endpoint de Mercado Pago en Administración.");
    const order=orderSnapshot(data,"Mercado Pago / iniciado");
    const res=await fetch(endpoint,{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify(order)
    });
    if(!res.ok)throw new Error("No se pudo iniciar Mercado Pago.");
    const out=await res.json();
    const url=out.init_point||out.sandbox_init_point||out.url;
    if(!url)throw new Error("El backend no devolvió el enlace de pago.");
    saveOrder(order);
    window.location.href=url;
  }catch(e){alert(e.message)}
}

/* ADMIN */
function openAdmin(){
  document.getElementById("adminPanel").classList.add("show");
  document.body.style.overflow="hidden";
}
function closeAdmin(){
  document.getElementById("adminPanel").classList.remove("show");
  document.body.style.overflow="";
}
function loginAdmin(){
  const pass=document.getElementById("adminPass").value;
  if(pass!==settings.adminPassword)return alert("Contraseña incorrecta.");
  document.getElementById("adminLogin").classList.add("hidden");
  document.getElementById("adminShell").classList.remove("hidden");
  renderAdminDashboard();
}
function adminView(view,btn){
  document.querySelectorAll(".side-btn").forEach(b=>b.classList.remove("active")); if(btn)btn.classList.add("active");
  const title={dashboard:"Dashboard",products:"Productos",categories:"Categorías",orders:"Pedidos",settings:"Configuración"}[view];
  document.getElementById("adminTitle").textContent=title;
  document.getElementById("adminPrimary").style.display=view==="products"?"inline-flex":"none";
  if(view==="dashboard")renderAdminDashboard();
  if(view==="products")renderAdminProducts();
  if(view==="categories")renderAdminCategories();
  if(view==="orders")renderAdminOrders();
  if(view==="settings")renderAdminSettings();
}
function renderAdminDashboard(){
  const revenue=orders.filter(o=>String(o.payment).includes("Mercado Pago")).reduce((s,o)=>s+o.total,0);
  document.getElementById("adminContent").innerHTML=`
    <div class="stats">
      <div class="stat"><small>Productos</small><strong>${products.length}</strong></div>
      <div class="stat"><small>Pedidos</small><strong>${orders.length}</strong></div>
      <div class="stat"><small>Sin stock</small><strong>${products.filter(p=>p.stock<=0).length}</strong></div>
      <div class="stat"><small>Ventas MP iniciadas</small><strong>${money(revenue)}</strong></div>
    </div>
    <div class="admin-card"><h3>Últimos pedidos</h3>${orders.length?orders.slice(0,5).map(o=>`<p><strong>#${o.id}</strong> · ${escapeHtml(o.customer.name)} · ${money(o.total)} · ${escapeHtml(o.payment)}</p>`).join(""):"<p>No hay pedidos todavía.</p>"}</div>`;
}
function renderAdminProducts(){
  document.getElementById("adminContent").innerHTML=`<div class="admin-card"><table>
    <thead><tr><th>Producto</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Destacado</th><th></th></tr></thead>
    <tbody>${products.map(p=>`<tr>
      <td>${escapeHtml(p.name)}</td><td>${escapeHtml(p.category)}</td><td>${money(p.price)}</td><td>${p.stock}</td><td>${p.featured?"Sí":"No"}</td>
      <td><button class="small-btn edit" onclick="openProductForm(${p.id})">Editar</button> <button class="small-btn delete" onclick="deleteProduct(${p.id})">Eliminar</button></td>
    </tr>`).join("")}</tbody></table></div>`;
}
function openProductForm(id=null){
  editingProductId=id;
  const p=id?products.find(x=>x.id===id):{name:"",category:"",price:"",stock:"",featured:false,image:""};
  document.getElementById("adminContent").innerHTML=`<div class="admin-card">
    <h3>${id?"Editar":"Agregar"} producto</h3>
    <div class="admin-form">
      <div><label>Nombre</label><input class="field" id="pName" value="${escapeAttr(p.name)}"></div>
      <div><label>Categoría</label><input class="field" id="pCategory" value="${escapeAttr(p.category)}" placeholder="Velas"></div>
      <div><label>Precio</label><input class="field" id="pPrice" type="number" value="${p.price}"></div>
      <div><label>Stock</label><input class="field" id="pStock" type="number" value="${p.stock}"></div>
      <div class="full"><label>URL de imagen</label><input class="field" id="pImage" value="${escapeAttr(p.image||"")}" placeholder="https://..."></div>
      <div class="full"><label><input type="checkbox" id="pFeatured" ${p.featured?"checked":""}> Producto destacado</label></div>
      <div class="full"><button class="btn btn-primary" onclick="saveProduct()">Guardar producto</button> <button class="btn btn-soft" onclick="renderAdminProducts()">Cancelar</button></div>
    </div></div>`;
}
function saveProduct(){
  const obj={
    id:editingProductId||Date.now(),
    name:document.getElementById("pName").value.trim(),
    category:document.getElementById("pCategory").value.trim(),
    price:Number(document.getElementById("pPrice").value||0),
    stock:Number(document.getElementById("pStock").value||0),
    image:document.getElementById("pImage").value.trim(),
    featured:document.getElementById("pFeatured").checked
  };
  if(!obj.name||!obj.category)return alert("Completá nombre y categoría.");
  if(editingProductId)products=products.map(p=>p.id===editingProductId?obj:p);else products.unshift(obj);
  persist();renderFilters();renderProducts();renderAdminProducts();
}
function deleteProduct(id){
  if(!confirm("¿Eliminar este producto?"))return;
  products=products.filter(p=>p.id!==id);cart=cart.filter(i=>i.id!==id);persist();renderFilters();renderProducts();renderCart();renderAdminProducts();
}
function renderAdminCategories(){
  document.getElementById("adminContent").innerHTML=`<div class="admin-card"><h3>Categorías actuales</h3>
    ${categories().filter(c=>c!=="Todos").map(c=>`<p>${escapeHtml(c)}</p>`).join("")}
    <p class="notice">Las categorías se crean automáticamente al asignarlas a un producto. Para renombrar una categoría, editá los productos que la usan.</p></div>`;
}
function renderAdminOrders(){
  document.getElementById("adminContent").innerHTML=`<div class="admin-card"><table>
    <thead><tr><th>Pedido</th><th>Cliente</th><th>Entrega</th><th>Total</th><th>Pago</th><th>Estado</th></tr></thead>
    <tbody>${orders.map(o=>`<tr>
      <td>#${o.id}</td><td>${escapeHtml(o.customer.name)}</td><td>${o.customer.delivery==="delivery"?escapeHtml(o.customer.address):"Retiro"}</td>
      <td>${money(o.total)}</td><td>${escapeHtml(o.payment)}</td>
      <td><select class="select" onchange="changeOrderStatus(${o.id},this.value)">
        ${["Nuevo","Preparando","Listo","Entregado","Cancelado"].map(s=>`<option ${o.status===s?"selected":""}>${s}</option>`).join("")}
      </select></td>
    </tr>`).join("")}</tbody></table></div>`;
}
function changeOrderStatus(id,status){const o=orders.find(x=>x.id===id);if(o)o.status=status;persist()}
function renderAdminSettings(){
  document.getElementById("adminContent").innerHTML=`<div class="admin-card">
    <div class="admin-form">
      <div><label>WhatsApp con código de país</label><input class="field" id="sWhatsapp" value="${escapeAttr(settings.whatsapp)}" placeholder="549351..."></div>
      <div><label>Instagram Córdoba</label><input class="field" id="sInstagram" value="${escapeAttr(settings.instagram)}" placeholder="@amorina..."></div>
      <div class="full"><label>Dirección de retiro</label><input class="field" id="sPickup" value="${escapeAttr(settings.pickupAddress)}"></div>
      <div><label>Costo de envío</label><input class="field" id="sShipping" type="number" value="${settings.shippingCost}"></div>
      <div><label>Envío gratis desde</label><input class="field" id="sFree" type="number" value="${settings.freeShippingFrom}"></div>
      <div class="full"><label>Endpoint seguro Mercado Pago</label><input class="field" id="sMp" value="${escapeAttr(settings.mpEndpoint)}"></div>
      <div class="full"><label>Contraseña admin (solo demo local)</label><input class="field" id="sPass" type="password" value="${escapeAttr(settings.adminPassword)}"></div>
      <div class="full"><button class="btn btn-primary" onclick="saveSettings()">Guardar configuración</button></div>
    </div></div>`;
}
function saveSettings(){
  settings.whatsapp=document.getElementById("sWhatsapp").value.trim();
  settings.instagram=document.getElementById("sInstagram").value.trim();
  settings.pickupAddress=document.getElementById("sPickup").value.trim();
  settings.shippingCost=Number(document.getElementById("sShipping").value||0);
  settings.freeShippingFrom=Number(document.getElementById("sFree").value||0);
  settings.mpEndpoint=document.getElementById("sMp").value.trim();
  settings.adminPassword=document.getElementById("sPass").value||settings.adminPassword;
  persist();updatePublicSettings();alert("Configuración guardada.");
}
function updatePublicSettings(){
  document.getElementById("footerInstagram").textContent=settings.instagram?`${settings.instagram} · Córdoba`:"Home Scents · Córdoba";
}

function escapeHtml(s=""){return String(s).replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]))}
function escapeAttr(s=""){return escapeHtml(s)}
function escapeJs(s=""){return String(s).replace(/\\/g,"\\\\").replace(/'/g,"\\'")}

document.getElementById("year").textContent=new Date().getFullYear();
renderFilters();renderProducts();renderCart();updatePublicSettings();

if(location.hash==="#admin")openAdmin();
</script>
</body>
</html>
